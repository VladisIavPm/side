# ============================================
# Скрипт для создания папки
# ============================================

log "=== СОЗДАНИЕ ПАПКИ ==="

set folder_name = "моя_новая_папка"

# Проверяем, существует ли уже такая папка
check file_exists(folder_name) start
    log "Папка '" + folder_name + "' уже существует"
else start
    # Создаём папку
    create_dir(folder_name)
    log "Папка '" + folder_name + "' успешно создана"
end

# Показываем содержимое текущей папки (чтобы убедиться)
log "\n=== СОДЕРЖИМОЕ ТЕКУЩЕЙ ПАПКИ ==="
set files = list_dir(".")
set i = 0
loop i < len(files) start
    log "  " + files[i]
    set i = i + 1
end

log "\n=== ГОТОВО ==="