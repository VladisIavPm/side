# ============================================
# Скрипт для создания папки (с вводом имени)
# ============================================

log "=== СОЗДАНИЕ ПАПКИ ==="

set folder_name = entry "Введите имя папки: "

# Проверяем, существует ли уже такая папка
check file_exists(folder_name) start
    log "❌ Папка '" + folder_name + "' уже существует"
else start
    # Создаём папку
    create_dir(folder_name)
    log "✅ Папка '" + folder_name + "' успешно создана"
end

log "\n=== ГОТОВО ==="